{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["../web/src/*"],
      "@cli/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../web/src/modules/**/*.ts", "../web/src/shared/**/*.ts"]
}
