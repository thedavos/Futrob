# Application (public values are safe for the browser)
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
VITE_APP_BASE_URL=http://localhost:3000

# Better Auth (server only; persists to D1 when scaffolded)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Cloudflare (local/dev placeholders; production uses Wrangler bindings + secrets)
# D1, R2, Queues, and Cron are bound in wrangler.jsonc — not connection strings.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# EA Clubs provider (server only)
EA_CLUBS_BASE_URL=https://proclubs.ea.com/api
EA_CLUBS_API_KEY=

# Email notifications (server only; provider chosen at adapter time)
EMAIL_FROM=
EMAIL_PROVIDER_API_KEY=

# Sentry (leave blank to disable event delivery locally)
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Signed internal job / queue consumer auth (server only)
INTERNAL_JOB_SECRET=
